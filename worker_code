/**
 * STATION IMAGE PROXY - v1.9
 * Standardized Endpoint Naming & Consolidated DOT Section
 */

const CACHE_VERSION = 1; 

// Global Layout Constants
const LAYOUT_1_COL = { w: 1735, h: 720 }; // Wide
const LAYOUT_2_COL = { w: 852, h: 720 };  // Split

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const imgKey = url.searchParams.get("img");

    if (!imgKey) return new Response("Error: Missing img parameter", { status: 400 });

    const REFRESH_TIMES = {
      '1-column': 1200, // 20 Minutes
      '2-column': 300   // 5 Minutes
    };

    const IMAGES = {
      // River Levels (NOAA)
      "redriverlevel": { 
        src: "https://water.noaa.gov/resources/hydrographs/fgon8_hg.png", 
        layout: LAYOUT_1_COL, 
        type: '1-column' 
      },

      // DOT Cameras (NDDOT)
      "cam-i29i94-west": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelwest.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      },
      "cam-i29i94-east": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/fargotrileveleast.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      },
      "cam-i29i94-north": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelnorth.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      },
      "cam-i29i94-south": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelsouth.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      },
      "cam-i94redriver-east": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverEast.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      },
      "cam-i94redriver-west": { 
        src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverWest.jpg", 
        layout: LAYOUT_2_COL, 
        type: '2-column' 
      }
    };

    const cfg = IMAGES[imgKey];
    if (!cfg) return new Response("Error: Invalid image key", { status: 404 });

    const ttl = REFRESH_TIMES[cfg.type];
    const bucket = Math.floor(Date.now() / 1000 / ttl);
    
    const weservURL = `https://images.weserv.nl/?url=${encodeURIComponent(cfg.src)}&w=${cfg.layout.w}&h=${cfg.layout.h}&fit=contain&bg=transparent&v=${CACHE_VERSION}&time=${bucket}`;

    try {
      const res = await fetch(weservURL, {
        headers: { "User-Agent": "FireStationDisplay/1.9" }
      });

      if (!res.ok) throw new Error("Source Down");

      return new Response(res.body, {
        headers: {
          "Content-Type": "image/png",
          "Cache-Control": `public, max-age=${ttl}, must-revalidate`,
          "X-System-Version": CACHE_VERSION.toString()
        }
      });

    } catch (err) {
      return generateFallback(cfg.layout.w, cfg.layout.h);
    }
  }
};

function generateFallback(width, height) {
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}">
    <rect width="100%" height="100%" fill="#111111"/>
    <text x="50%" y="45%" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-weight="bold" font-size="32" fill="#e74c3c">
      IMAGE UNAVAILABLE
    </text>
    <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="20" fill="#bdc3c7">
      Check source provider or retry shortly.
    </text>
  </svg>`;
  
  return new Response(svg, {
    status: 503,
    headers: { "Content-Type": "image/svg+xml", "Cache-Control": "no-store" }
  });
}
