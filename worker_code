/**
 * FIRE STATION DISPLAY PROXY - VERSION 1.5
 * * NOTE: If images ever get "stuck" again, simply change the 
 * 'CACHE_VERSION' number below (e.g., change 1 to 2).
 */
const CACHE_VERSION = 1; 

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const imgKey = url.searchParams.get("img");

    if (!imgKey) return new Response("Missing img parameter", { status: 400 });

    const REFRESH_TIMES = {
      noaa: 1200,    // 20 minutes
      traffic: 300   // 5 minutes
    };

    const IMAGES = {
      noaa: { src: "https://water.noaa.gov/resources/hydrographs/fgon8_hg.png", w: 1735, h: 720, type: 'noaa' },
      "cam-west": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelwest.jpg", w: 852, h: 720, type: 'traffic' },
      "cam-east": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrileveleast.jpg", w: 852, h: 720, type: 'traffic' },
      "cam-north": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelnorth.jpg", w: 852, h: 720, type: 'traffic' },
      "cam-south": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelsouth.jpg", w: 852, h: 720, type: 'traffic' },
      "cam-redriver-east": { src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverEast.jpg", w: 852, h: 720, type: 'traffic' },
      "cam-redriver-west": { src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverWest.jpg", w: 852, h: 720, type: 'traffic' }
    };

    const cfg = IMAGES[imgKey];
    if (!cfg) return new Response("Invalid key", { status: 404 });

    const ttl = REFRESH_TIMES[cfg.type];

    /**
     * DYNAMIC CACHE BUSTING
     * bucket: Changes every 5 or 20 minutes automatically.
     * CACHE_VERSION: Manually changes whenever you edit this code.
     */
    const bucket = Math.floor(Date.now() / 1000 / ttl);
    const weservURL = `https://images.weserv.nl/?url=${encodeURIComponent(cfg.src)}&w=${cfg.w}&h=${cfg.h}&fit=contain&bg=transparent&v=${CACHE_VERSION}&time=${bucket}`;

    try {
      const res = await fetch(weservURL, {
        headers: { "User-Agent": "FireStationDisplay/1.5" },
        // On workers.dev, we use standard fetch caching
      });

      if (!res.ok) throw new Error();

      return new Response(res.body, {
        headers: {
          "Content-Type": "image/png",
          "Cache-Control": `public, max-age=${ttl}, must-revalidate`,
          "X-Refresh-Version": CACHE_VERSION.toString()
        }
      });
    } catch (err) {
      return new Response("Error loading image", { status: 503 });
    }
  }
};
