export default {
  async fetch(request) {
    try {
      const url = new URL(request.url);
      const imgKey = url.searchParams.get("img");

      if (!imgKey) return new Response("Missing img parameter", { status: 400 });

      // Layout sizes
      const LAYOUT_SIZES = {
        "1-column": { width: 1735, height: 720 }, // NOAA gauge
        "2-column": { width: 852, height: 720 }   // Traffic cams
      };

      // Refresh intervals (seconds)
      const REFRESH_TIMES = {
        noaa: 3600,    // 1 hour
        traffic: 600   // 10 minutes
      };

      // Image configuration
      const IMAGES = {
        noaa: { src: "https://water.noaa.gov/resources/hydrographs/fgon8_hg.png", layout: "1-column" },
        "cam-west": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelwest.jpg", layout: "2-column" },
        "cam-east": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrileveleast.jpg", layout: "2-column" },
        "cam-north": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelnorth.jpg", layout: "2-column" },
        "cam-south": { src: "https://www.dot.nd.gov/travel-info/cameras/fargotrilevelsouth.jpg", layout: "2-column" },
        "cam-redriver-east": { src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverEast.jpg", layout: "2-column" },
        "cam-redriver-west": { src: "https://www.dot.nd.gov/travel-info/cameras/I94RP352FargoRedRiverWest.jpg", layout: "2-column" }
      };

      const cfg = IMAGES[imgKey];
      if (!cfg) return new Response("Invalid image key", { status: 404 });

      const { width, height } = LAYOUT_SIZES[cfg.layout];

      // Weserv URL with resizing, padding, transparency
      const weservURL = `https://images.weserv.nl/?url=${encodeURIComponent(cfg.src)}&w=${width}&h=${height}&fit=contain&bg=transparent`;

      const res = await fetch(weservURL);
      if (!res.ok) throw new Error("Failed to fetch image from Weserv");

      return new Response(res.body, {
        headers: {
          "Content-Type": res.headers.get("Content-Type") || "image/png",
          "Cache-Control": `public, max-age=${cfg.layout === "1-column" ? REFRESH_TIMES.noaa : REFRESH_TIMES.traffic}`
        }
      });

    } catch (err) {
      return fallbackImage();
    }
  }
};

// Fallback image with heading + subheading
function fallbackImage(width = 852, height = 720) {
  const svg = `
<svg xmlns="http://www.w3.org/2000/svg" width="${width}" height="${height}">
  <rect width="100%" height="100%" fill="#000000"/>
  <text x="50%" y="40%"
        dominant-baseline="middle"
        text-anchor="middle"
        font-family="Arial, Helvetica, sans-serif"
        font-size="36"
        fill="#FFFFFF">
    Service temporarily unavailable
  </text>
  <text x="50%" y="60%"
        dominant-baseline="middle"
        text-anchor="middle"
        font-family="Arial, Helvetica, sans-serif"
        font-size="24"
        fill="#FFFFFF">
    The image will return as soon as the service is available again
  </text>
</svg>`;

  return new Response(svg, {
    status: 503,
    headers: { "Content-Type": "image/svg+xml", "Cache-Control": "no-store" }
  });
}
